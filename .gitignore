# Python-generated files
__pycache__/
*.py[oc]
build/
dist/
wheels/
*.egg-info

# Virtual environments
.venv

# Node
node_modules
npm-debug.log*

# Next.js
.next/
out/

# PWA service worker (generated at build time by next-pwa, not committed)
public/sw.js
public/swe-worker-*.js
public/workbox-*.js

# Vercel
.vercel

# SQLite WAL temp files (the .db file itself IS committed for persistence)
data/*.db-shm
data/*.db-wal
# Uploaded product assets (large binary files)
public/assets/*.jpeg
public/assets/*.jpg
public/assets/*.png
public/assets/*.webp
public/assets/*.gif

# Env files
.env
.env.local
.env*.local
.env.production
