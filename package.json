{
  "name": "postlain-store-manager",
  "version": "2.2.1",
  "private": true,
  "scripts": {
    "dev": "next dev --port 3000",
    "build": "NODE_OPTIONS=--max-old-space-size=512 next build",
    "start": "next start",
    "lint": "next lint",
    "seed": "node scripts/seed.js",
    "patch": "npm version patch --no-git-tag-version && git add package.json && git commit -m \"chore: bump patch version\" && git push",
    "minor": "npm version minor --no-git-tag-version && git add package.json && git commit -m \"chore: bump minor version\" && git push",
    "major": "npm version major --no-git-tag-version && git add package.json && git commit -m \"chore: bump major version\" && git push",
    "docker:build": "docker compose build",
    "docker:up": "docker compose up -d",
    "docker:down": "docker compose down",
    "docker:logs": "docker compose logs -f postlain-store",
    "postinstall": "node node_modules/better-sqlite3/scripts/build-release.js 2>/dev/null || true"
  },
  "dependencies": {
    "@ducanh2912/next-pwa": "^10.2.9",
    "@supabase/supabase-js": "^2.49.4",
    "@zxing/browser": "^0.1.5",
    "@zxing/library": "^0.21.3",
    "barcode-detector": "^3.1.1",
    "better-sqlite3": "^12.8.0",
    "exceljs": "^4.4.0",
    "framer-motion": "^11.15.0",
    "jsqr": "^1.4.0",
    "lucide-react": "^0.577.0",
    "next": "^15.1.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "web-push": "^3.6.7",
    "xlsx": "^0.18.5",
    "zustand": "^5.0.2"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^22",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/web-push": "^3.6.4",
    "autoprefixer": "^10.4.20",
    "eslint": "^8",
    "eslint-config-next": "^15.1.0",
    "postcss": "^8.4.47",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.7.2"
  }
}
