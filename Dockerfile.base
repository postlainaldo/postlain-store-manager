# Build once, push to registry, reuse forever
# docker build -f Dockerfile.base -t postlainaldo/node-build-base:20 .
# docker push postlainaldo/node-build-base:20
FROM node:20-bookworm-slim
RUN apt-get update && apt-get install -y --no-install-recommends \
    python3 make g++ && rm -rf /var/lib/apt/lists/*
