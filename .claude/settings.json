{
  "permissions": {
    "allow": [
      "Bash(git add *)",
      "Bash(git commit *)",
      "Bash(git push)",
      "Bash(git status)",
      "Bash(git log *)",
      "Bash(git diff *)",
      "Bash(npm run build)",
      "Bash(npm run lint)",
      "Bash(mkdir *)",
      "Bash(ls *)",
      "WebSearch",
      "WebFetch(domain:nextjs.org)",
      "WebFetch(domain:supabase.com)",
      "WebFetch(domain:github.com)",
      "WebFetch(domain:exceljs.github.io)",
      "WebFetch(domain:coolify.io)"
    ],
    "deny": [
      "Bash(git push --force*)",
      "Bash(git reset --hard*)",
      "Bash(rm -rf*)",
      "Bash(git commit --amend*)"
    ]
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "echo '[hook] File saved. Remember: git add + commit + push after finishing task.'"
          }
        ]
      }
    ]
  }
}
