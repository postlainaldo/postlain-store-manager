// ─────────────────────────────────────────────────────────────────────────────
// POSTLAIN — Store Manager · Prisma Schema
// Lead Architect design · Centric-inspired inventory management
// ─────────────────────────────────────────────────────────────────────────────

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ─────────────────────────────────────────────────────────────────────────────
// ENUMS
// ─────────────────────────────────────────────────────────────────────────────

enum ProductStatus {
  ACTIVE      // Đang bán
  ARCHIVED    // Ngừng bán / hết mùa
  DRAFT       // Chưa ra mắt
  MARKDOWN    // Đang giảm giá
}

enum CollectionStatus {
  SKETCH      // Bản thảo thiết kế
  SAMPLING    // Đang làm mẫu
  PRODUCTION  // Đang sản xuất
  RELEASED    // Đã ra mắt
  ARCHIVED    // Kết thúc vòng đời
}

enum LocationType {
  WAREHOUSE   // Kho chính (backstock)
  STORE_SHELF // Kệ trưng bày trong cửa hàng
  WINDOW      // Tủ kính / cửa sổ
  FITTING     // Phòng thử đồ (samples)
  TRANSIT     // Đang vận chuyển giữa điểm
}

enum Gender {
  WOMEN
  MEN
  KIDS
  UNISEX
}

enum StockMovementType {
  RECEIVE     // Nhập kho từ nhà cung cấp
  TRANSFER    // Chuyển kho nội bộ
  SALE        // Bán ra
  RETURN      // Khách trả hàng
  ADJUSTMENT  // Điều chỉnh kiểm kê
  MARKDOWN    // Chuyển sang khu markdown
}

// ─────────────────────────────────────────────────────────────────────────────
// COLLECTION — vòng đời từ sketch → release
// ─────────────────────────────────────────────────────────────────────────────

model Collection {
  id          String           @id @default(cuid())
  name        String           // "SS25 Women", "FW24 Men"
  season      String           // "SS25", "FW24"
  year        Int
  gender      Gender
  status      CollectionStatus @default(SKETCH)
  description String?
  launchDate  DateTime?
  endDate     DateTime?

  products    Product[]

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([season, year])
  @@index([status])
}

// ─────────────────────────────────────────────────────────────────────────────
// PRODUCT — thông tin gốc của một mặt hàng (chưa có size/color)
// ─────────────────────────────────────────────────────────────────────────────

model Product {
  id           String        @id @default(cuid())
  name         String
  description  String?
  category     String        // "Giày nữ", "Túi nam", "Phụ kiện", ...
  productType  String?       // key từ PRODUCT_TYPES catalog (e.g. "SNEAKER", "BOOT")
  gender       Gender        @default(WOMEN)
  basePrice    Float         // Giá gốc (full price)
  markdownPrice Float?       // Giá giảm (nếu đang markdown)
  status       ProductStatus @default(ACTIVE)
  imagePath    String?       // Đường dẫn ảnh đại diện
  notes        String?

  collectionId String?
  collection   Collection?   @relation(fields: [collectionId], references: [id], onDelete: SetNull)

  variants     ProductVariant[]
  tags         ProductTag[]

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([category])
  @@index([status])
  @@index([collectionId])
}

// ─────────────────────────────────────────────────────────────────────────────
// COLOR — bảng màu chuẩn của thương hiệu
// ─────────────────────────────────────────────────────────────────────────────

model Color {
  id       String @id @default(cuid())
  name     String @unique // "Jet Black", "Nude Beige", "Sand Camel"
  code     String @unique // Mã nội bộ: "BLK001", "NUD002"
  hex      String         // "#1A1410"
  family   String         // "Neutral", "Earth", "Jewel", ...

  variants ProductVariant[]
}

// ─────────────────────────────────────────────────────────────────────────────
// PRODUCT VARIANT — trung tâm của hệ thống, ma trận Color × Size
// Mỗi dòng = 1 SKU duy nhất. Đây là đơn vị được quản lý tồn kho.
// ─────────────────────────────────────────────────────────────────────────────

model ProductVariant {
  id          String        @id @default(cuid())
  sku         String        @unique // "ALDO-DR001-BLK-38"
  barcode     String?       @unique
  productId   String
  product     Product       @relation(fields: [productId], references: [id], onDelete: Cascade)
  colorId     String
  color       Color         @relation(fields: [colorId], references: [id])
  size        String        // "36", "37", "38", "S", "M", "L", "ONE SIZE"
  sizeSystem  String        @default("EU") // "EU", "US", "UK", "FR", "IT", "VN"
  priceOverride Float?      // Nếu variant này có giá khác product.basePrice
  status      ProductStatus @default(ACTIVE)
  imagePath   String?       // Ảnh riêng của variant (nếu có)

  stockItems  StockItem[]
  movements   StockMovement[]
  orderItems  OrderItem[]

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([productId])
  @@index([colorId])
  @@index([sku])
  @@index([status])
}

// ─────────────────────────────────────────────────────────────────────────────
// LOCATION — mọi nơi có thể chứa hàng
// ─────────────────────────────────────────────────────────────────────────────

model Location {
  id          String       @id @default(cuid())
  name        String       // "Kho Chính A", "Kệ Trưng Bày 01 — Tầng 3"
  code        String       @unique // "WH-A", "SHELF-01-T3", "WINDOW-FRONT"
  type        LocationType
  aisle       String?      // Dãy kệ: "A", "B", "C"
  bay         String?      // Vị trí trong dãy: "01", "02"
  tier        Int?         // Tầng (1 = thấp nhất)
  slot        Int?         // Ô trong tầng (1-based)
  capacity    Int          @default(25) // Số lượng tối đa có thể chứa
  notes       String?
  isActive    Boolean      @default(true)

  stockItems  StockItem[]
  fromMovements StockMovement[] @relation("FromLocation")
  toMovements   StockMovement[] @relation("ToLocation")

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([type])
  @@index([isActive])
  @@index([code])
}

// ─────────────────────────────────────────────────────────────────────────────
// STOCK ITEM — liên kết Variant ↔ Location với số lượng thực tế
// "Giày đen size 38 đang nằm ở Kệ 01 tầng 3 còn 2 đôi"
// ─────────────────────────────────────────────────────────────────────────────

model StockItem {
  id         String         @id @default(cuid())
  variantId  String
  variant    ProductVariant @relation(fields: [variantId], references: [id], onDelete: Cascade)
  locationId String
  location   Location       @relation(fields: [locationId], references: [id], onDelete: Restrict)
  quantity   Int            @default(0) // Số lượng hiện tại tại vị trí này
  reservedQty Int           @default(0) // Số lượng đã đặt trước / đang chờ xử lý
  minAlert   Int            @default(1) // Cảnh báo khi còn dưới mức này
  displayRow Int?           // Hàng trên kệ trưng bày (1-based)
  displayPos Int?           // Vị trí trong hàng (1-based)

  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  // Một variant chỉ có một bản ghi tại mỗi location
  @@unique([variantId, locationId])
  @@index([variantId])
  @@index([locationId])
  @@index([quantity])
}

// ─────────────────────────────────────────────────────────────────────────────
// STOCK MOVEMENT — lịch sử mọi biến động tồn kho (audit trail)
// ─────────────────────────────────────────────────────────────────────────────

model StockMovement {
  id             String            @id @default(cuid())
  type           StockMovementType
  variantId      String
  variant        ProductVariant    @relation(fields: [variantId], references: [id])
  fromLocationId String?
  fromLocation   Location?         @relation("FromLocation", fields: [fromLocationId], references: [id])
  toLocationId   String?
  toLocation     Location?         @relation("ToLocation", fields: [toLocationId], references: [id])
  quantity       Int               // Số lượng di chuyển (luôn dương)
  note           String?           // Lý do / ghi chú
  reference      String?           // Số PO, số đơn hàng, ...
  performedBy    String?           // User ID hoặc tên nhân viên

  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([variantId])
  @@index([type])
  @@index([fromLocationId])
  @@index([toLocationId])
  @@index([createdAt])
}

// ─────────────────────────────────────────────────────────────────────────────
// TAG — nhãn linh hoạt cho product (nhiều-nhiều)
// ─────────────────────────────────────────────────────────────────────────────

model Tag {
  id       String       @id @default(cuid())
  name     String       @unique // "Bestseller", "New Arrival", "Exclusive"
  color    String       @default("#B8914A") // hex hiển thị trên UI
  products ProductTag[]
}

model ProductTag {
  productId String
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  tagId     String
  tag       Tag     @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([productId, tagId])
}

// ─────────────────────────────────────────────────────────────────────────────
// ORDER — đơn hàng (bán ra / nhập về)
// ─────────────────────────────────────────────────────────────────────────────

model Order {
  id          String      @id @default(cuid())
  orderNumber String      @unique // "ORD-2025-0001"
  type        String      // "SALE" | "PURCHASE" | "RETURN"
  status      String      @default("PENDING") // "PENDING" | "CONFIRMED" | "COMPLETED" | "CANCELLED"
  totalAmount Float
  currency    String      @default("VND")
  customerName String?
  notes       String?

  items       OrderItem[]

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([status])
  @@index([type])
  @@index([createdAt])
}

model OrderItem {
  id        String         @id @default(cuid())
  orderId   String
  order     Order          @relation(fields: [orderId], references: [id], onDelete: Cascade)
  variantId String
  variant   ProductVariant @relation(fields: [variantId], references: [id])
  quantity  Int
  unitPrice Float
  discount  Float          @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([orderId])
  @@index([variantId])
}
