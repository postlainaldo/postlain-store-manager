// Postlain Store Manager — Prisma Schema
// Database: SQLite (local dev, zero-config)

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ─── Product ──────────────────────────────────────────────────────────────────
model Product {
  id            String   @id @default(cuid())
  name          String
  sku           String?  @unique
  category      String
  productType   String?
  quantity      Int      @default(0)
  price         Float?
  markdownPrice Float?
  color         String?
  size          String?
  imagePath     String?
  notes         String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  placements    Placement[]

  @@index([category])
  @@index([sku])
}

// ─── Shelf ────────────────────────────────────────────────────────────────────
// Covers both WarehouseShelf and StoreSection subsections

model Shelf {
  id        String    @id @default(cuid())
  name      String
  type      ShelfType
  subType   String?   // "shoes"|"bags" for warehouse; sectionType for display
  sortOrder Int       @default(0)

  slots     Slot[]
}

enum ShelfType {
  WAREHOUSE
  DISPLAY
}

// ─── Slot ─────────────────────────────────────────────────────────────────────
model Slot {
  id        String     @id @default(cuid())
  shelfId   String
  shelf     Shelf      @relation(fields: [shelfId], references: [id], onDelete: Cascade)
  tier      Int        // warehouse: tier 0-3 | display: rowIndex
  position  Int        // warehouse: 0-24    | display: slotIndex
  label     String     @default("") // display: subsectionId; warehouse: ""

  placement Placement?

  @@unique([shelfId, tier, position, label])
  @@index([shelfId])
}

// ─── Placement ────────────────────────────────────────────────────────────────
model Placement {
  id        String   @id @default(cuid())
  productId String
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  slotId    String   @unique
  slot      Slot     @relation(fields: [slotId], references: [id], onDelete: Cascade)
  placedAt  DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([productId])
}
